<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FANFIG — Complete Community System</title>
  <meta name="description" content="FANFIG เว็บอ่านและเขียนแฟนฟิค / นิยาย พร้อมระบบสมาชิก คลังสาธารณะ คอมเมนต์ ไลก์ บุ๊กมาร์ก และ Firebase" />
  <style>
    :root {
      --bg: #090914;
      --bg2: #111124;
      --card: rgba(255,255,255,.08);
      --card2: rgba(255,255,255,.13);
      --text: #f8f7ff;
      --muted: #b9b7d8;
      --line: rgba(255,255,255,.14);
      --brand: #ff4fd8;
      --brand2: #7c5cff;
      --brand3: #00e0ff;
      --ok: #4dffb5;
      --warn: #ffd166;
      --danger: #ff5c7a;
      --shadow: 0 24px 70px rgba(0,0,0,.38);
      --radius: 22px;
      --max: 1200px;
      --font: "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, "Noto Sans Thai", sans-serif;
    }
    [data-theme="light"] {
      --bg: #f6f3ff;
      --bg2: #ffffff;
      --card: rgba(255,255,255,.78);
      --card2: rgba(255,255,255,.96);
      --text: #17172b;
      --muted: #5c5d7d;
      --line: rgba(31,30,70,.13);
      --shadow: 0 20px 55px rgba(61,45,122,.14);
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: var(--font);
      color: var(--text);
      min-height: 100vh;
      background:
        radial-gradient(circle at 10% 8%, rgba(255,79,216,.28), transparent 25%),
        radial-gradient(circle at 84% 10%, rgba(0,224,255,.16), transparent 30%),
        radial-gradient(circle at 48% 86%, rgba(124,92,255,.23), transparent 34%),
        var(--bg);
      overflow-x: hidden;
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
      background-size: 48px 48px;
      mask-image: linear-gradient(to bottom, black, transparent 82%);
      z-index: 0;
    }
    button, input, textarea, select { font: inherit; }
    button { border: 0; cursor: pointer; }
    a { color: inherit; text-decoration: none; }
    .app { position: relative; z-index: 1; min-height: 100vh; }
    .topbar {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(18px);
      background: rgba(9,9,20,.74);
      border-bottom: 1px solid var(--line);
    }
    [data-theme="light"] .topbar { background: rgba(246,243,255,.78); }
    .nav {
      max-width: var(--max);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      padding: 13px 18px;
    }
    .brand { display: flex; align-items: center; gap: 12px; font-weight: 950; letter-spacing: .6px; }
    .logo {
      width: 44px; height: 44px; border-radius: 16px;
      display: grid; place-items: center; color: #fff;
      background: linear-gradient(135deg, var(--brand), var(--brand2), var(--brand3));
      box-shadow: 0 12px 30px rgba(124,92,255,.28);
      transform: rotate(-3deg);
    }
    .brand small { display:block; color: var(--muted); font-size: 12px; letter-spacing:0; font-weight:800; margin-top:-2px; }
    .nav-actions { display:flex; align-items:center; justify-content:flex-end; gap:8px; flex-wrap:wrap; }
    .btn, .nav-btn, .primary, .danger, .soft {
      border-radius: 999px;
      padding: 10px 14px;
      color: var(--text);
      background: var(--card);
      border: 1px solid var(--line);
      transition: .2s ease;
      white-space: nowrap;
      font-weight: 800;
    }
    .btn:hover, .nav-btn:hover, .soft:hover { transform: translateY(-1px); background: var(--card2); }
    .nav-btn.active { background: linear-gradient(135deg, rgba(255,79,216,.24), rgba(124,92,255,.24)); border-color: rgba(255,255,255,.26); }
    .primary { background: linear-gradient(135deg, var(--brand), var(--brand2)); color: #fff; border-color: transparent; box-shadow: 0 16px 35px rgba(124,92,255,.26); }
    .primary:hover { transform: translateY(-1px) scale(1.01); filter: brightness(1.05); }
    .danger { background: rgba(255,92,122,.16); border-color: rgba(255,92,122,.38); color: #ffd7df; }
    .danger:hover { background: rgba(255,92,122,.24); transform: translateY(-1px); }
    .container { max-width: var(--max); margin: 0 auto; padding: 24px 18px 72px; }
    .hero { display:grid; grid-template-columns: 1.05fr .95fr; gap: 22px; align-items: stretch; padding: 34px 0 16px; }
    .panel, .hero-card, .story-card, .reader, .modal-card {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, var(--card2), var(--card));
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .hero-card { padding: 34px; position: relative; overflow: hidden; }
    .hero-card::after { content:""; position:absolute; right:-70px; top:-70px; width:240px; height:240px; border-radius:50%; background: radial-gradient(circle, rgba(255,79,216,.34), transparent 68%); }
    .eyebrow { display:inline-flex; gap:8px; align-items:center; border:1px solid var(--line); background:rgba(255,255,255,.08); color:var(--muted); padding:8px 12px; border-radius:999px; font-weight:850; font-size:13px; }
    h1 { margin: 18px 0 12px; font-size: clamp(36px, 6vw, 68px); line-height:.96; letter-spacing:-2px; }
    .gradient-text { background: linear-gradient(90deg, var(--brand), #ffd6f6, var(--brand3)); -webkit-background-clip:text; background-clip:text; color:transparent; }
    .lead { color:var(--muted); line-height:1.82; font-size:17px; max-width:780px; }
    .hero-actions, .row { display:flex; flex-wrap:wrap; gap:9px; align-items:center; }
    .hero-actions { margin-top: 22px; }
    .stats { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-top:26px; }
    .stat { padding:16px; border-radius:18px; background:rgba(255,255,255,.07); border:1px solid var(--line); }
    .stat b { display:block; font-size:28px; margin-bottom:2px; }
    .stat span { color:var(--muted); font-size:13px; font-weight:800; }
    .feature-panel { padding:22px; display:grid; gap:14px; }
    .feature { padding:18px; border-radius:18px; background:rgba(255,255,255,.07); border:1px solid var(--line); }
    .feature h3 { margin:0 0 6px; font-size:17px; }
    .feature p { margin:0; color:var(--muted); line-height:1.68; font-size:14px; }
    .section-head { display:flex; justify-content:space-between; align-items:flex-end; gap:18px; margin:34px 0 16px; }
    .section-head h2 { margin:0; font-size: clamp(25px, 3vw, 36px); letter-spacing:-.6px; }
    .section-head p { margin:6px 0 0; color:var(--muted); line-height:1.65; }
    .controls { display:grid; grid-template-columns: 1fr 180px 160px 160px; gap:10px; margin:14px 0 18px; }
    .field { width:100%; border-radius:16px; border:1px solid var(--line); color:var(--text); background:rgba(255,255,255,.08); outline:none; padding:13px 14px; transition:.2s ease; }
    .field:focus { border-color:rgba(255,79,216,.56); box-shadow:0 0 0 4px rgba(255,79,216,.11); }
    textarea.field { min-height:160px; resize:vertical; line-height:1.75; }
    option { color:#111; background:#fff; }
    .chips { display:flex; flex-wrap:wrap; gap:8px; margin: 0 0 18px; }
    .chip { padding:9px 12px; border-radius:999px; border:1px solid var(--line); background:rgba(255,255,255,.07); color:var(--muted); transition:.2s ease; font-weight:850; }
    .chip:hover, .chip.active { color:var(--text); background:linear-gradient(135deg, rgba(255,79,216,.22), rgba(0,224,255,.16)); transform:translateY(-1px); }
    .grid { display:grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap:16px; }
    .story-card { overflow:hidden; transition:.24s ease; position:relative; }
    .story-card:hover { transform:translateY(-4px); border-color:rgba(255,255,255,.28); }
    .cover { min-height:174px; padding:20px; display:flex; align-items:flex-end; position:relative; overflow:hidden; background:linear-gradient(135deg, rgba(255,79,216,.72), rgba(124,92,255,.72)); }
    .cover::before { content:""; position:absolute; inset:-1px; background:radial-gradient(circle at 80% 10%, rgba(255,255,255,.35), transparent 18%), linear-gradient(130deg, transparent 0 44%, rgba(255,255,255,.16) 45% 47%, transparent 48%); }
    .cover h3 { position:relative; z-index:1; margin:0; font-size:24px; line-height:1.12; color:#fff; text-shadow:0 8px 20px rgba(0,0,0,.28); }
    .story-body { padding:18px; }
    .meta { display:flex; flex-wrap:wrap; gap:7px; margin:0 0 11px; }
    .badge { font-size:12px; color:var(--text); background:rgba(255,255,255,.10); border:1px solid var(--line); border-radius:999px; padding:5px 8px; font-weight:850; }
    .badge.ok { color:#caffea; background:rgba(77,255,181,.13); border-color:rgba(77,255,181,.28); }
    .badge.warn { color:#fff0c4; background:rgba(255,209,102,.12); border-color:rgba(255,209,102,.28); }
    .desc { margin:0 0 14px; color:var(--muted); line-height:1.62; font-size:14px; min-height:68px; }
    .story-foot { display:flex; justify-content:space-between; align-items:center; gap:8px; border-top:1px solid var(--line); padding-top:13px; color:var(--muted); font-size:13px; font-weight:800; }
    .icon-btn { min-width:38px; height:38px; border-radius:14px; display:grid; place-items:center; color:var(--text); background:rgba(255,255,255,.08); border:1px solid var(--line); transition:.2s ease; padding:0 10px; font-weight:900; }
    .icon-btn:hover { transform:translateY(-1px); background:rgba(255,255,255,.15); }
    .icon-btn.active { background:rgba(255,209,102,.18); border-color:rgba(255,209,102,.45); }
    .write-layout { display:grid; grid-template-columns:.92fr 1.08fr; gap:16px; align-items:start; }
    .panel { padding:20px; }
    .panel h3 { margin:0 0 12px; font-size:21px; }
    .form-grid { display:grid; gap:10px; }
    .two { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
    .hint { color:var(--muted); line-height:1.75; font-size:14px; }
    .empty { padding:34px; text-align:center; color:var(--muted); border:1px dashed var(--line); border-radius:var(--radius); background:rgba(255,255,255,.045); }
    .reader { padding:0; overflow:hidden; display:none; margin-top:24px; }
    .reader.active { display:block; }
    .reader-cover { padding:34px; background:linear-gradient(135deg, rgba(255,79,216,.6), rgba(124,92,255,.55), rgba(0,224,255,.28)); }
    .reader-cover h2 { font-size:clamp(30px,5vw,54px); margin:8px 0 10px; line-height:1; color:#fff; }
    .reader-cover p { margin:0; max-width:780px; color:rgba(255,255,255,.86); line-height:1.75; }
    .reader-content { padding:26px 34px 34px; }
    .chapter-tabs { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:18px; }
    .chapter-tab { padding:10px 13px; border-radius:999px; border:1px solid var(--line); color:var(--muted); background:rgba(255,255,255,.07); font-weight:900; }
    .chapter-tab.active { color:var(--text); background:linear-gradient(135deg, rgba(255,79,216,.24), rgba(124,92,255,.24)); }
    .chapter-text { font-size:17px; color:var(--text); line-height:2; white-space:pre-line; padding:22px; border-radius:18px; background:rgba(255,255,255,.055); border:1px solid var(--line); }
    .comment-area, .owner-tools, .profile-grid { margin-top:20px; }
    .comments { display:grid; gap:10px; margin-top:12px; }
    .comment { padding:13px 14px; border-radius:16px; background:rgba(255,255,255,.07); border:1px solid var(--line); color:var(--muted); line-height:1.65; }
    .comment b { color:var(--text); }
    .modal { position:fixed; inset:0; display:none; place-items:center; z-index:90; padding:18px; background:rgba(0,0,0,.58); backdrop-filter:blur(8px); }
    .modal.active { display:grid; }
    .modal-card { width:min(660px,100%); padding:22px; max-height:92vh; overflow:auto; }
    .modal-head { display:flex; justify-content:space-between; align-items:center; gap:14px; margin-bottom:12px; }
    .modal-head h3 { margin:0; font-size:25px; }
    .auth-user { display:none; align-items:center; gap:8px; max-width:250px; }
    .auth-user.active { display:flex; }
    .avatar { width:36px; height:36px; border-radius:50%; object-fit:cover; border:2px solid rgba(255,255,255,.28); background:linear-gradient(135deg,var(--brand),var(--brand2)); }
    .name { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-size:13px; font-weight:900; }
    .auth-divider { display:flex; align-items:center; gap:12px; color:var(--muted); margin:16px 0; font-size:13px; }
    .auth-divider::before, .auth-divider::after { content:""; height:1px; flex:1; background:var(--line); }
    .message { min-height:22px; margin:10px 0 0; color:var(--danger); font-size:13px; font-weight:800; }
    .sync { font-size:12px; color:var(--muted); text-align:center; margin-top:12px; }
    .toast { position:fixed; left:50%; bottom:24px; transform:translateX(-50%) translateY(30px); background:rgba(10,10,24,.88); color:#fff; border:1px solid rgba(255,255,255,.18); border-radius:999px; padding:12px 18px; box-shadow:var(--shadow); z-index:100; opacity:0; pointer-events:none; transition:.25s ease; backdrop-filter:blur(14px); font-weight:900; }
    .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
    .footer { border-top:1px solid var(--line); color:var(--muted); padding:28px 18px; text-align:center; line-height:1.7; background:rgba(0,0,0,.12); }
    .hide { display:none !important; }
    .profile-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; }
    .mini-list { display:grid; gap:10px; }
    .mini-item { padding:13px; border-radius:16px; background:rgba(255,255,255,.065); border:1px solid var(--line); display:flex; justify-content:space-between; gap:10px; align-items:center; }
    .legal-box { padding:16px; border-radius:18px; border:1px solid rgba(255,209,102,.35); background:rgba(255,209,102,.10); color:var(--muted); line-height:1.7; }
    @media (max-width: 980px) {
      .hero, .write-layout { grid-template-columns:1fr; }
      .grid { grid-template-columns:repeat(2,minmax(0,1fr)); }
      .controls { grid-template-columns:1fr 1fr; }
      .controls input { grid-column:1/-1; }
    }
    @media (max-width: 680px) {
      .brand-text { display:none; }
      .nav { align-items:flex-start; }
      .btn, .nav-btn, .primary, .danger, .soft { padding:9px 11px; font-size:13px; }
      .hero-card { padding:24px; }
      .stats, .grid, .controls, .two, .profile-grid { grid-template-columns:1fr; }
      .section-head { flex-direction:column; align-items:flex-start; }
      .reader-cover, .reader-content { padding:22px; }
      .chapter-text { padding:16px; font-size:16px; }
    }
    @media print {
      .topbar, .hero, .controls, .chips, .section-head, #library, #write, #profile, .footer, .comment-area, .reader-actions, .owner-tools { display:none !important; }
      body { background:#fff !important; color:#111 !important; }
      .container { padding:0 !important; max-width:none !important; }
      .reader { display:block !important; box-shadow:none !important; border:0 !important; }
      .reader-cover { background:#fff !important; color:#111 !important; padding:0 0 12px !important; border-bottom:2px solid #111; }
      .reader-cover h2, .reader-cover p { color:#111 !important; }
      .reader-content { padding:12px 0 !important; }
      .chapter-tabs { display:none !important; }
      .chapter-text { border:0 !important; background:transparent !important; color:#111 !important; padding:0 !important; }
    }
  </style>
</head>
<body>
<div class="app" id="app" data-theme="dark">
  <header class="topbar">
    <nav class="nav">
      <a href="#home" class="brand" aria-label="FANFIG Home">
        <div class="logo">✦</div>
        <div class="brand-text"><div>FANFIG</div><small>อ่าน • เขียน • แชร์</small></div>
      </a>
      <div class="nav-actions">
        <button class="nav-btn active" data-nav="home">หน้าแรก</button>
        <button class="nav-btn" data-nav="library">คลังฟิค</button>
        <button class="nav-btn" data-nav="bookmarks">บุ๊กมาร์ก</button>
        <button class="nav-btn" data-nav="write">เขียนฟิค</button>
        <button class="nav-btn" data-nav="profile">โปรไฟล์</button>
        <button class="btn" id="themeBtn">🌙 ธีม</button>
        <button class="primary" id="loginBtn">เข้าสู่ระบบ</button>
        <div class="auth-user" id="authUser">
          <img class="avatar" id="authAvatar" alt="" />
          <span class="name" id="authUserName"></span>
          <button class="btn" id="logoutBtn">ออก</button>
        </div>
      </div>
    </nav>
  </header>

  <main class="container">
    <section class="hero" id="home">
      <div class="hero-card">
        <span class="eyebrow">✨ FANFIG Complete — Community Ready</span>
        <h1>เว็บแฟนฟิคที่พร้อมเป็น <span class="gradient-text">ชุมชนนักเขียน</span></h1>
        <p class="lead">เวอร์ชันนี้เพิ่มระบบหลักให้ครบขึ้น: คลังฟิคสาธารณะผ่าน Firebase, สมัคร/เข้าสู่ระบบ, เจ้าของแก้ไข/ลบ/เพิ่มตอนได้, ไลก์, บุ๊กมาร์ก, คอมเมนต์, รายงานเนื้อหา, โปรไฟล์ และโหมดสำรองแบบ localStorage หากยังไม่ได้ตั้ง Firebase</p>
        <div class="hero-actions">
          <button class="primary" data-scroll="library">เริ่มอ่านเลย</button>
          <button class="btn" data-scroll="write">+ เขียนเรื่องใหม่</button>
          <button class="btn" id="randomBtn">🎲 สุ่มเรื่องอ่าน</button>
          <button class="btn" id="exportBtn">⬇️ Export JSON</button>
        </div>
        <div class="stats">
          <div class="stat"><b id="statStories">0</b><span>เรื่องทั้งหมด</span></div>
          <div class="stat"><b id="statChapters">0</b><span>ตอนทั้งหมด</span></div>
          <div class="stat"><b id="statBookmarks">0</b><span>บุ๊กมาร์กของฉัน</span></div>
          <div class="stat"><b id="statUsers">1</b><span>สถานะระบบ</span></div>
        </div>
      </div>
      <aside class="feature-panel panel">
        <div class="feature"><h3>🌐 Public Library</h3><p>เมื่อเชื่อม Firebase แล้ว ทุกคนจะเห็นเรื่องจากคอลเลกชันเดียวกัน ไม่แยกเป็นคลังส่วนตัวเหมือนเวอร์ชันก่อน</p></div>
        <div class="feature"><h3>🛡️ Owner Controls</h3><p>เจ้าของเรื่องเท่านั้นที่เห็นปุ่มแก้ไข ลบ เพิ่มตอน และจัดการตอน ลดปัญหาคนอื่นแก้เรื่องของเรา</p></div>
        <div class="feature"><h3>💬 Reader System</h3><p>ผู้อ่านสามารถไลก์ บุ๊กมาร์ก คอมเมนต์ รายงานเรื่อง และพิมพ์ตอนอ่านได้</p></div>
      </aside>
    </section>

    <section id="library">
      <div class="section-head">
        <div><h2>คลัง FANFIG</h2><p id="libraryNote">ระบบจะใช้ Firebase เมื่อพร้อม และใช้ข้อมูลในเครื่องเป็นสำรอง</p></div>
        <div class="row"><button class="btn" id="refreshBtn">รีเฟรช</button><button class="danger" id="resetBtn">รีเซ็ต Local</button></div>
      </div>
      <div class="controls">
        <input class="field" id="searchInput" type="search" placeholder="ค้นหาชื่อเรื่อง / ผู้แต่ง / คำโปรย..." />
        <select class="field" id="sortSelect"><option value="newest">ใหม่ล่าสุด</option><option value="popular">ยอดนิยม</option><option value="az">A-Z</option><option value="updated">อัปเดตล่าสุด</option></select>
        <select class="field" id="statusSelect"><option value="all">ทุกสถานะ</option><option value="ongoing">กำลังเขียน</option><option value="complete">จบแล้ว</option></select>
        <select class="field" id="scopeSelect"><option value="all">ทุกเรื่อง</option><option value="mine">เรื่องของฉัน</option><option value="liked">ที่ฉันไลก์</option></select>
      </div>
      <div class="chips" id="categoryChips"></div>
      <div class="grid" id="storyGrid"></div>
    </section>

    <section class="reader" id="reader">
      <div class="reader-cover" id="readerCover">
        <div class="meta" id="readerMeta"></div>
        <h2 id="readerTitle">ชื่อเรื่อง</h2>
        <p id="readerDesc">คำอธิบาย</p>
      </div>
      <div class="reader-content">
        <div class="reader-actions row" style="margin-bottom:16px;">
          <button class="btn" id="backToLibrary">← กลับไปคลังฟิค</button>
          <button class="btn" id="readerLike">♡ ไลก์</button>
          <button class="btn" id="readerBookmark">☆ บุ๊กมาร์ก</button>
