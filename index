    toast.timer = setTimeout(() => el.classList.remove("show"), 1900);
  }
  function setSync(message) { $("#syncStatus").textContent = message; $("#footerMode").textContent = "โหมด: " + message; }
  function isOwner(story) { return Boolean(currentUser && story?.ownerUid === currentUser.uid); }
  function isLiked(story) { return (story?.likedBy || []).includes(uid()) || localLikes.includes(story?.id); }
  function isBookmarked(id) { return bookmarks.includes(id); }

  function storyToFirestore(story) {
    return {
      title: story.title,
      author: story.author,
      category: story.category,
      status: story.status,
      desc: story.desc,
      cover: story.cover || "",
      ownerUid: story.ownerUid,
      ownerName: story.ownerName || story.author,
      ownerPhoto: story.ownerPhoto || "",
      views: Number(story.views || 0),
      likesCount: Number(story.likesCount || 0),
      bookmarksCount: Number(story.bookmarksCount || 0),
      likedBy: story.likedBy || [],
      createdAt: story.createdAt || now(),
      updatedAt: now(),
      accent: story.accent || randomPalette(),
      chapters: story.chapters || [],
      comments: story.comments || []
    };
  }
  function docToStory(doc) {
    const data = doc.data();
    return {
      id: doc.id,
      cloud: true,
      ...data,
      createdAt: normalizeTime(data.createdAt),
      updatedAt: normalizeTime(data.updatedAt),
      views: Number(data.views || 0),
      likesCount: Number(data.likesCount || 0),
      bookmarksCount: Number(data.bookmarksCount || 0),
      likedBy: Array.isArray(data.likedBy) ? data.likedBy : [],
      chapters: Array.isArray(data.chapters) ? data.chapters : [],
      comments: Array.isArray(data.comments) ? data.comments : []
    };
  }
  function randomPalette() {
    const palettes = [["#ff4fd8","#7c5cff"],["#00e0ff","#7c5cff"],["#ffd166","#ff5c7a"],["#4dffb5","#00e0ff"],["#ff7ab6","#ffd166"],["#a78bfa","#22d3ee"]];
    return palettes[Math.floor(Math.random() * palettes.length)];
  }

  function initializeFirebase() {
    try {
      if (!window.firebase) throw new Error("Firebase SDK not loaded");
      firebase.initializeApp(firebaseConfig);
      auth = firebase.auth();
      db = firebase.firestore();
      auth.onAuthStateChanged(async user => {
        currentUser = user;
        updateAuthUI();
        if (user) {
          await db.collection("users").doc(user.uid).set({
            displayName: user.displayName || "",
            email: user.email || "",
            photoURL: user.photoURL || "",
            lastLoginAt: firebase.firestore.FieldValue.serverTimestamp()
          }, { merge: true });
          await loadUserProfile();
          listenPublicStories();
        } else {
          currentUser = null;
          bookmarks = loadArray(LOCAL_BOOKMARKS);
          listenPublicStories();
        }
      });
    } catch (error) {
      console.warn(error);
      onlineMode = false;
      setSync("Local only • ยังไม่เชื่อม Firebase");
      renderAll();
    }
  }

  async function loadUserProfile() {
    if (!currentUser || !db) return;
    try {
      const ref = db.collection("users").doc(currentUser.uid).collection("profile").doc("app");
      const snap = await ref.get();
      if (snap.exists) {
        const data = snap.data();
        bookmarks = Array.isArray(data.bookmarks) ? data.bookmarks : [];
      } else {
        await ref.set({ bookmarks, updatedAt: firebase.firestore.FieldValue.serverTimestamp() }, { merge: true });
      }
      saveArray(LOCAL_BOOKMARKS, bookmarks);
    } catch (error) {
      console.error(error);
      bookmarks = loadArray(LOCAL_BOOKMARKS);
    }
  }

  function listenPublicStories() {
    if (!db) { renderAll(); return; }
    if (unsubscribeStories) unsubscribeStories();
    setSync("กำลังเชื่อม Firebase...");
    unsubscribeStories = db.collection("stories").orderBy("createdAt", "desc").onSnapshot(snapshot => {
      onlineMode = true;
      const cloudStories = snapshot.docs.map(docToStory);
      stories = cloudStories.length ? cloudStories : loadLocalStories();
      $("#libraryNote").textContent = cloudStories.length ? "กำลังใช้คลังสาธารณะจาก Firebase แบบเรียลไทม์" : "Firebase พร้อมแล้ว แต่ยังไม่มีเรื่องในระบบ จึงแสดงข้อมูลตัวอย่าง";
      setSync(cloudStories.length ? "Firebase online • Public Library" : "Firebase online • ยังไม่มีข้อมูลจริง");
      renderAll();
    }, error => {
      console.error(error);
      onlineMode = false;
      stories = loadLocalStories();
      $("#libraryNote").textContent = "โหลด Firebase ไม่สำเร็จ จึงใช้ข้อมูลในเครื่องแทน";
      setSync("Local fallback • Firebase อ่านไม่ได้");
      renderAll();
    });
  }

  async function saveUserBookmarks() {
    saveArray(LOCAL_BOOKMARKS, bookmarks);
    if (currentUser && db) {
      await db.collection("users").doc(currentUser.uid).collection("profile").doc("app").set({
        bookmarks,
        updatedAt: firebase.firestore.FieldValue.serverTimestamp()
      }, { merge: true });
    }
  }

  async function createOrUpdateStory(event) {
    event.preventDefault();
    const editingId = $("#editingStoryId").value;
    const title = $("#titleField").value.trim();
    const author = $("#authorField").value.trim();
    const category = $("#categoryField").value;
    const status = $("#statusField").value;
    const desc = $("#descField").value.trim();
    const cover = $("#coverField").value.trim();
    const chapterTitle = $("#chapterTitleField").value.trim();
    const chapterBody = $("#chapterBodyField").value.trim();
    if (!title || !author || !category || !desc) return toast("กรอกข้อมูลเรื่องให้ครบก่อนนะ");

    if (editingId) {
      const story = stories.find(s => s.id === editingId);
      if (!story || !isOwner(story)) return toast("แก้ไขได้เฉพาะเจ้าของเรื่อง");
      const update = { title, author, category, status, desc, cover, updatedAt: now() };
      Object.assign(story, update);
      if (story.cloud && db) {
        await db.collection("stories").doc(story.id).set(update, { merge: true });
      } else {
        saveLocalStories();
        renderAll();
      }
      cancelEdit();
      toast("อัปเดตข้อมูลเรื่องแล้ว ✨");
      openReader(story.id, currentChapterIndex);
      return;
    }

    if (!chapterTitle || !chapterBody) return toast("กรอกชื่อตอนแรกและเนื้อหาตอนแรกก่อนนะ");
    const story = {
      id: randomId(),
      title, author, category, status, desc, cover,
      ownerUid: currentUser?.uid || uid(),
      ownerName: currentUser?.displayName || author,
      ownerPhoto: currentUser?.photoURL || "",
      views: 0, likesCount: 0, bookmarksCount: 0, likedBy: [],
      createdAt: now(), updatedAt: now(), accent: randomPalette(),
      chapters: [{ id: randomId(), title: chapterTitle, body: chapterBody, createdAt: now(), updatedAt: now() }],
      comments: []
    };

    if (currentUser && db && onlineMode) {
      const doc = await db.collection("stories").add(storyToFirestore(story));
      toast("เผยแพร่ลงคลังสาธารณะแล้ว 🚀");
      $("#storyForm").reset();
      openReader(doc.id);
    } else {
      stories.unshift(story);
      saveLocalStories();
      toast("บันทึกเป็น Local Draft แล้ว • ล็อกอินเพื่อเผยแพร่จริง");
      $("#storyForm").reset();
      renderAll();
      openReader(story.id);
    }
  }

  async function updateStoryDoc(story, patch) {
    Object.assign(story, patch, { updatedAt: now() });
    if (story.cloud && db) await db.collection("stories").doc(story.id).set({ ...patch, updatedAt: now() }, { merge: true });
    else { saveLocalStories(); renderAll(); }
  }

  async function deleteCurrentStory() {
    const story = getCurrentStory();
    if (!story || !isOwner(story)) return;
    if (story.cloud && db) await db.collection("stories").doc(story.id).delete();
    else { stories = stories.filter(s => s.id !== story.id); saveLocalStories(); renderAll(); }
    currentStoryId = null;
    $("#reader").classList.remove("active");
    toast("ลบเรื่องแล้ว");
  }

  function startEditStory() {
    const story = getCurrentStory();
    if (!story || !isOwner(story)) return toast("แก้ไขได้เฉพาะเจ้าของเรื่อง");
    $("#editingStoryId").value = story.id;
    $("#titleField").value = story.title || "";
    $("#authorField").value = story.author || "";
    $("#categoryField").value = story.category || "";
    $("#statusField").value = story.status || "ongoing";
    $("#descField").value = story.desc || "";
    $("#coverField").value = story.cover || "";
    $("#firstChapterFields").classList.add("hide");
    $("#formTitle").textContent = "แก้ไขข้อมูลเรื่อง";
    $("#submitStoryBtn").textContent = "บันทึกการแก้ไข";
    $("#cancelEditBtn").classList.remove("hide");
    $("#write").scrollIntoView({ behavior: "smooth" });
  }
  function cancelEdit() {
    $("#editingStoryId").value = "";
    $("#storyForm").reset();
    $("#firstChapterFields").classList.remove("hide");
    $("#formTitle").textContent = "ข้อมูลเรื่อง";
    $("#submitStoryBtn").textContent = "เผยแพร่ลงคลัง";
    $("#cancelEditBtn").classList.add("hide");
    if (currentUser) $("#authorField").value = currentUser.displayName || "";
  }

  function openChapterModal() {
    const story = getCurrentStory();
    if (!story || !isOwner(story)) return;
    $("#chapterSelect").innerHTML = '<option value="new">+ เพิ่มตอนใหม่</option>' + story.chapters.map((c, i) => `<option value="${i}">${escapeHtml(c.title)}</option>`).join("");
    $("#chapterSelect").value = "new";
    $("#chapterEditTitle").value = "";
    $("#chapterEditBody").value = "";
    $("#deleteChapterBtn").classList.add("hide");
    $("#chapterModal").classList.add("active");
  }
  function loadChapterIntoForm() {
    const story = getCurrentStory();
    const val = $("#chapterSelect").value;
    if (!story || val === "new") {
      $("#chapterEditTitle").value = "";
      $("#chapterEditBody").value = "";
      $("#deleteChapterBtn").classList.add("hide");
      return;
    }
    const chapter = story.chapters[Number(val)];
    $("#chapterEditTitle").value = chapter?.title || "";
    $("#chapterEditBody").value = chapter?.body || "";
    $("#deleteChapterBtn").classList.toggle("hide", story.chapters.length <= 1);
  }
  async function saveChapter() {
    const story = getCurrentStory();
    if (!story || !isOwner(story)) return;
    const title = $("#chapterEditTitle").value.trim();
    const body = $("#chapterEditBody").value.trim();
    if (!title || !body) return toast("กรอกชื่อตอนและเนื้อหาก่อนนะ");
    const val = $("#chapterSelect").value;
    const chapters = structuredClone(story.chapters || []);
    if (val === "new") chapters.push({ id: randomId(), title, body, createdAt: now(), updatedAt: now() });
    else chapters[Number(val)] = { ...chapters[Number(val)], title, body, updatedAt: now() };
    await updateStoryDoc(story, { chapters });
    $("#chapterModal").classList.remove("active");
    currentChapterIndex = val === "new" ? chapters.length - 1 : Number(val);
    toast("บันทึกตอนแล้ว");
    openReader(story.id, currentChapterIndex);
  }
  async function deleteChapter() {
    const story = getCurrentStory();
    if (!story || !isOwner(story) || story.chapters.length <= 1) return;
    const idx = Number($("#chapterSelect").value);
    if (Number.isNaN(idx)) return;
    const chapters = structuredClone(story.chapters);
    chapters.splice(idx, 1);
    await updateStoryDoc(story, { chapters });
    $("#chapterModal").classList.remove("active");
    currentChapterIndex = 0;
    toast("ลบตอนแล้ว");
    openReader(story.id, 0);
  }

  async function toggleLike(id) {
    const story = stories.find(s => s.id === id);
    if (!story) return;
    const actor = uid();
    const active = isLiked(story);
    if (story.cloud && db) {
      await db.collection("stories").doc(story.id).update({
        likedBy: active ? firebase.firestore.FieldValue.arrayRemove(actor) : firebase.firestore.FieldValue.arrayUnion(actor),
        likesCount: firebase.firestore.FieldValue.increment(active ? -1 : 1),
        updatedAt: firebase.firestore.FieldValue.serverTimestamp()
      });
    } else {
      story.likedBy = story.likedBy || [];
      if (active) { story.likedBy = story.likedBy.filter(x => x !== actor); localLikes = localLikes.filter(x => x !== id); story.likesCount = Math.max(0, (story.likesCount || 0) - 1); }
      else { story.likedBy.push(actor); if (!localLikes.includes(id)) localLikes.push(id); story.likesCount = (story.likesCount || 0) + 1; }
      saveArray(LOCAL_LIKES, localLikes);
      saveLocalStories();
      renderAll();
    }
    toast(active ? "นำออกจากเรื่องที่ไลก์แล้ว" : "กดไลก์แล้ว ♡");
    renderReaderButtons();
  }

  async function toggleBookmark(id) {
    const active = bookmarks.includes(id);
    bookmarks = active ? bookmarks.filter(x => x !== id) : [...bookmarks, id];
    await saveUserBookmarks();
    const story = stories.find(s => s.id === id);
    if (story) {
      if (story.cloud && db) await db.collection("stories").doc(story.id).update({ bookmarksCount: firebase.firestore.FieldValue.increment(active ? -1 : 1) }).catch(()=>{});
      else { story.bookmarksCount = Math.max(0, (story.bookmarksCount || 0) + (active ? -1 : 1)); saveLocalStories(); }
    }
    toast(active ? "นำออกจากบุ๊กมาร์กแล้ว" : "เพิ่มเข้าบุ๊กมาร์กแล้ว ★");
    renderAll();
    renderReaderButtons();
  }

  async function addComment() {
    const story = getCurrentStory();
    if (!story) return;
    const name = ($("#commentName").value.trim() || currentUser?.displayName || "นักอ่านนิรนาม").slice(0, 40);
    const text = $("#commentText").value.trim();
    if (!text) return toast("กรุณาเขียนคอมเมนต์ก่อนนะ");
    const comment = { id: randomId(), uid: uid(), name, text, time: now() };
    if (story.cloud && db) await db.collection("stories").doc(story.id).update({ comments: firebase.firestore.FieldValue.arrayUnion(comment), updatedAt: firebase.firestore.FieldValue.serverTimestamp() });
    else { story.comments = story.comments || []; story.comments.push(comment); saveLocalStories(); renderComments(); }
    $("#commentText").value = "";
    toast("ส่งคอมเมนต์แล้ว 💬");
  }

  async function sendReport() {
    const story = getCurrentStory();
    if (!story) return;
    const report = { storyId: story.id, storyTitle: story.title, reporterUid: uid(), reason: $("#reportReason").value, detail: $("#reportText").value.trim(), time: now() };
    if (db && onlineMode) await db.collection("reports").add({ ...report, createdAt: firebase.firestore.FieldValue.serverTimestamp() });
    else {
      const reports = loadArray("fanfig_reports_local_v2");
      reports.push(report);
      saveArray("fanfig_reports_local_v2", reports);
    }
    $("#reportText").value = "";
    $("#reportModal").classList.remove("active");
    toast("ส่งรายงานแล้ว ขอบคุณที่ช่วยดูแลชุมชน");
  }

  async function incrementView(story) {
    const viewed = loadArray(VIEWED_KEY);
    const key = `${story.id}:${new Date().toISOString().slice(0,10)}`;
    if (viewed.includes(key)) return;
    viewed.push(key);
    saveArray(VIEWED_KEY, viewed.slice(-600));
    story.views = (story.views || 0) + 1;
    if (story.cloud && db) await db.collection("stories").doc(story.id).update({ views: firebase.firestore.FieldValue.increment(1) }).catch(()=>{});
    else saveLocalStories();
  }

  function getCurrentStory() { return stories.find(s => s.id === currentStoryId); }
  async function openReader(id, chapterIndex = 0) {
    const story = stories.find(s => s.id === id);
    if (!story) return;
    currentStoryId = id;
    currentChapterIndex = Math.min(chapterIndex, Math.max(0, (story.chapters || []).length - 1));
    await incrementView(story);
    $("#reader").classList.add("active");
    $("#readerTitle").textContent = story.title;
    $("#readerDesc").textContent = story.desc;
    const bg = story.cover ? `linear-gradient(135deg, rgba(0,0,0,.35), rgba(0,0,0,.25)), url('${story.cover.replaceAll("'", "%27")}') center/cover` : `linear-gradient(135deg, ${story.accent?.[0] || "#ff4fd8"}, ${story.accent?.[1] || "#7c5cff"}, rgba(0,224,255,.32))`;
    $("#readerCover").style.background = bg;
    $("#readerMeta").innerHTML = `<span class="badge">#${escapeHtml(story.category)}</span><span class="badge ${story.status === "complete" ? "ok" : "warn"}">${story.status === "complete" ? "จบแล้ว" : "กำลังเขียน"}</span><span class="badge">โดย ${escapeHtml(story.author)}</span><span class="badge">👁 ${formatNumber(story.views)}</span><span class="badge">❤ ${formatNumber(story.likesCount)}</span>`;
    renderChapterTabs();
    renderChapterText();
    renderComments();
    renderReaderButtons();
    $("#ownerTools").classList.toggle("hide", !isOwner(story));
    $("#reader").scrollIntoView({ behavior: "smooth", block: "start" });
    renderStats();
    renderStories();
  }
  function renderChapterTabs() {
    const story = getCurrentStory();
    if (!story) return;
    $("#chapterTabs").innerHTML = (story.chapters || []).map((chapter, i) => `<button class="chapter-tab ${i === currentChapterIndex ? "active" : ""}" data-chapter="${i}">${escapeHtml(chapter.title || `ตอนที่ ${i+1}`)}</button>`).join("");
    $$('[data-chapter]').forEach(btn => btn.addEventListener("click", () => { currentChapterIndex = Number(btn.dataset.chapter); renderChapterTabs(); renderChapterText(); }));
  }
  function renderChapterText() {
    const story = getCurrentStory();
    const chapter = story?.chapters?.[currentChapterIndex];
    $("#chapterText").textContent = chapter?.body || "ยังไม่มีเนื้อหาในตอนนี้";
  }
  function renderComments() {
    const story = getCurrentStory();
    const comments = story?.comments || [];
    if (!comments.length) { $("#comments").innerHTML = `<div class="comment">ยังไม่มีคอมเมนต์ เป็นคนแรกที่คอมเมนต์ได้เลย ✨</div>`; return; }
    $("#comments").innerHTML = comments.slice().sort((a,b) => normalizeTime(b.time)-normalizeTime(a.time)).map(c => `<div class="comment"><b>${escapeHtml(c.name)}</b><small> • ${formatDate(c.time)}</small><br>${escapeHtml(c.text)}</div>`).join("");
  }
  function renderReaderButtons() {
    const story = getCurrentStory();
    if (!story) return;
    $("#readerLike").textContent = isLiked(story) ? "♥ ไลก์แล้ว" : "♡ ไลก์";
    $("#readerLike").classList.toggle("active", isLiked(story));
    $("#readerBookmark").textContent = isBookmarked(story.id) ? "★ บุ๊กมาร์กแล้ว" : "☆ บุ๊กมาร์ก";
    $("#readerBookmark").classList.toggle("active", isBookmarked(story.id));
  }

  function categories() { return ["all", ...new Set(stories.map(s => s.category).filter(Boolean))]; }
  function renderChips() {
    const labels = { all:"ทั้งหมด", Original:"ออริจินัล", Fanfiction:"แฟนฟิค", Romance:"โรแมนซ์", Action:"แอ็กชัน", Fantasy:"แฟนตาซี", Drama:"ดราม่า", Comedy:"คอมเมดี้", "School Life":"ชีวิตโรงเรียน", Adventure:"ผจญภัย", Horror:"สยองขวัญ", "Sci-Fi":"ไซไฟ" };
    $("#categoryChips").innerHTML = categories().map(cat => `<button class="chip ${activeCategory === cat ? "active" : ""}" data-category="${escapeHtml(cat)}">${labels[cat] || escapeHtml(cat)}</button>`).join("");
    $$('.chip').forEach(btn => btn.addEventListener("click", () => { activeCategory = btn.dataset.category; renderChips(); renderStories(); }));
  }
  function getFilteredStories() {
    const q = $("#searchInput").value.trim().toLowerCase();
    const sort = $("#sortSelect").value;
    const status = $("#statusSelect").value;
    const scope = $("#scopeSelect").value;
    let result = stories.filter(story => {
      const matchCategory = activeCategory === "all" || story.category === activeCategory;
      const matchStatus = status === "all" || story.status === status;
      const text = `${story.title} ${story.author} ${story.desc} ${story.category}`.toLowerCase();
      const matchScope = scope === "all" || (scope === "mine" && story.ownerUid === currentUser?.uid) || (scope === "liked" && isLiked(story));
      return matchCategory && matchStatus && text.includes(q) && matchScope;
    });
    if (sort === "newest") result.sort((a,b) => normalizeTime(b.createdAt)-normalizeTime(a.createdAt));
    if (sort === "updated") result.sort((a,b) => normalizeTime(b.updatedAt)-normalizeTime(a.updatedAt));
    if (sort === "popular") result.sort((a,b) => ((b.views||0)+(b.likesCount||0)*10)-((a.views||0)+(a.likesCount||0)*10));
    if (sort === "az") result.sort((a,b) => (a.title||"").localeCompare(b.title||""));
    return result;
  }
  function storyCard(story) {
    const gradient = story.cover ? `linear-gradient(135deg, rgba(0,0,0,.28), rgba(0,0,0,.15)), url('${story.cover.replaceAll("'", "%27")}') center/cover` : `linear-gradient(135deg, ${story.accent?.[0] || "#ff4fd8"}, ${story.accent?.[1] || "#7c5cff"})`;
    return `<article class="story-card">
      <div class="cover" style="background:${gradient};"><h3>${escapeHtml(story.title)}</h3></div>
      <div class="story-body">
        <div class="meta"><span class="badge">#${escapeHtml(story.category)}</span><span class="badge ${story.status === "complete" ? "ok" : "warn"}">${story.status === "complete" ? "จบแล้ว" : "กำลังเขียน"}</span><span class="badge">${story.chapters?.length || 0} ตอน</span>${isOwner(story) ? '<span class="badge ok">เจ้าของ</span>' : ''}</div>
        <p class="desc">${escapeHtml(story.desc)}</p>
        <div class="story-foot"><span>👁 ${formatNumber(story.views)} • ❤ ${formatNumber(story.likesCount)} • ★ ${formatNumber(story.bookmarksCount)}</span><div class="row" style="gap:7px;"><button class="icon-btn ${isBookmarked(story.id) ? "active" : ""}" data-bookmark="${story.id}">${isBookmarked(story.id) ? "★" : "☆"}</button><button class="icon-btn" data-read="${story.id}">อ่าน</button></div></div>
        <p class="hint" style="margin:12px 0 0;">โดย ${escapeHtml(story.author)} • อัปเดต ${formatDate(story.updatedAt || story.createdAt)}</p>
      </div>
    </article>`;
  }
  function renderStories() {
    const filtered = getFilteredStories();
    $("#storyGrid").innerHTML = filtered.length ? filtered.map(storyCard).join("") : `<div class="empty" style="grid-column:1/-1;">ไม่พบ FANFIG ที่ตรงกับการค้นหา ลองเปลี่ยนคำค้นหรือหมวดหมู่ดูนะ ✨</div>`;
    bindCardButtons($("#storyGrid"));
  }
  function renderBookmarkGrid() {
    const list = stories.filter(s => bookmarks.includes(s.id));
    $("#bookmarkGrid").innerHTML = list.length ? list.map(storyCard).join("") : `<div class="empty" style="grid-column:1/-1;">ยังไม่มีบุ๊กมาร์ก กด ☆ บนเรื่องที่ชอบเพื่อเก็บไว้ตรงนี้</div>`;
    bindCardButtons($("#bookmarkGrid"));
  }
  function bindCardButtons(root) {
    root.querySelectorAll('[data-read]').forEach(btn => btn.addEventListener("click", () => openReader(btn.dataset.read)));
    root.querySelectorAll('[data-bookmark]').forEach(btn => btn.addEventListener("click", e => { e.stopPropagation(); toggleBookmark(btn.dataset.bookmark); }));
  }
  function renderStats() {
    $("#statStories").textContent = stories.length;
    $("#statChapters").textContent = stories.reduce((sum,s) => sum + (s.chapters?.length || 0), 0);
    $("#statBookmarks").textContent = bookmarks.length;
    $("#statUsers").textContent = onlineMode ? "Online" : "Local";
  }
  function renderProfile() {
    const userName = currentUser?.displayName || currentUser?.email || "Guest Reader";
    $("#profileName").textContent = userName;
    $("#profileEmail").textContent = currentUser?.email || "ยังไม่ได้เข้าสู่ระบบ • ข้อมูลบางส่วนจะเก็บเฉพาะเครื่องนี้";
    $("#profileAvatar").src = currentUser?.photoURL || `https://ui-avatars.com/api/?name=${encodeURIComponent(userName)}&background=7c5cff&color=fff`;
    $("#profileLoginBtn").classList.toggle("hide", Boolean(currentUser));
    const mine = stories.filter(s => s.ownerUid === currentUser?.uid || (!currentUser && s.ownerUid === uid()));
    $("#myStoriesCount").textContent = mine.length;
    $("#myBookmarksCount").textContent = bookmarks.length;
    $("#myLikesCount").textContent = stories.filter(isLiked).length;
    $("#myStoryList").innerHTML = mine.length ? mine.map(s => `<div class="mini-item"><div><b>${escapeHtml(s.title)}</b><br><span class="hint">${s.chapters?.length || 0} ตอน • ${formatNumber(s.views)} วิว</span></div><button class="btn" data-read="${s.id}">เปิด</button></div>`).join("") : `<div class="empty">ยังไม่มีเรื่องของคุณ เริ่มเขียนเรื่องแรกได้ที่เมนู “เขียนฟิค”</div>`;
    bindCardButtons($("#myStoryList"));
  }
  function renderAll() {
    renderStats(); renderChips(); renderStories(); renderBookmarkGrid(); renderProfile();
    if (currentStoryId && stories.some(s => s.id === currentStoryId)) {
      const idx = currentChapterIndex;
      const story = getCurrentStory();
      $("#ownerTools").classList.toggle("hide", !isOwner(story));
      renderReaderButtons(); renderComments(); renderChapterTabs(); currentChapterIndex = idx; renderChapterText();
    }
  }

  function updateAuthUI() {
    const logged = Boolean(currentUser);
    $("#loginBtn").classList.toggle("hide", logged);
    $("#authUser").classList.toggle("active", logged);
    if (logged) {
      const name = currentUser.displayName || currentUser.email || "สมาชิก";
      $("#authUserName").textContent = name;
      $("#authAvatar").src = currentUser.photoURL || `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=7c5cff&color=fff`;
      if (!$("#authorField").value) $("#authorField").value = name;
      if (!$("#commentName").value) $("#commentName").value = name;
    }
    renderProfile();
  }
  function firebaseErrorMessage(error) {
    const map = { "auth/email-already-in-use":"อีเมลนี้ถูกใช้งานแล้ว", "auth/invalid-email":"รูปแบบอีเมลไม่ถูกต้อง", "auth/invalid-credential":"อีเมลหรือรหัสผ่านไม่ถูกต้อง", "auth/wrong-password":"รหัสผ่านไม่ถูกต้อง", "auth/user-not-found":"ไม่พบบัญชีนี้", "auth/weak-password":"รหัสผ่านต้องมีอย่างน้อย 6 ตัว", "auth/popup-closed-by-user":"หน้าต่างเข้าสู่ระบบถูกปิด", "auth/popup-blocked":"เบราว์เซอร์บล็อกหน้าต่างเข้าสู่ระบบ", "auth/account-exists-with-different-credential":"อีเมลนี้เคยสมัครด้วยวิธีอื่นแล้ว", "auth/operation-not-allowed":"ยังไม่ได้เปิดผู้ให้บริการนี้ใน Firebase Console", "auth/unauthorized-domain":"โดเมนนี้ยังไม่ได้เพิ่มใน Authorized domains" };
    return map[error?.code] || error?.message || "เกิดข้อผิดพลาด กรุณาลองใหม่";
  }
  async function signInEmail(e) {
    e.preventDefault();
    $("#authMessage").textContent = "";
    try { await auth.signInWithEmailAndPassword($("#authEmail").value.trim(), $("#authPassword").value); $("#authModal").classList.remove("active"); toast("เข้าสู่ระบบแล้ว"); }
    catch (error) { $("#authMessage").textContent = firebaseErrorMessage(error); }
  }
  async function signupEmail() {
    $("#authMessage").textContent = "";
    const email = $("#authEmail").value.trim();
    const password = $("#authPassword").value;
    const displayName = $("#authName").value.trim();
    if (!email || password.length < 6) { $("#authMessage").textContent = password.length < 6 ? "รหัสผ่านต้องมีอย่างน้อย 6 ตัว" : "กรุณากรอกอีเมล"; return; }
    try {
      const cred = await auth.createUserWithEmailAndPassword(email, password);
      if (displayName) await cred.user.updateProfile({ displayName });
      await db.collection("users").doc(cred.user.uid).set({ displayName, email, createdAt: firebase.firestore.FieldValue.serverTimestamp() }, { merge: true });
      $("#authModal").classList.remove("active"); toast("สมัครสมาชิกแล้ว");
    } catch (error) { $("#authMessage").textContent = firebaseErrorMessage(error); }
  }
  async function providerLogin(provider) {
    $("#authMessage").textContent = "";
    try { await auth.signInWithPopup(provider); $("#authModal").classList.remove("active"); toast("เข้าสู่ระบบแล้ว"); }
    catch (error) { $("#authMessage").textContent = firebaseErrorMessage(error); }
  }
  async function logout() { if (auth) await auth.signOut(); currentUser = null; updateAuthUI(); toast("ออกจากระบบแล้ว"); }

  function applyTheme(theme) { $("#app").setAttribute("data-theme", theme); $("#themeBtn").textContent = theme === "dark" ? "🌙 ธีม" : "☀️ ธีม"; localStorage.setItem(LOCAL_THEME, theme); }
  function randomStory() { if (!stories.length) return; openReader(stories[Math.floor(Math.random()*stories.length)].id); }
  function exportJson() {
    const data = { exportedAt: new Date().toISOString(), stories, bookmarks, likes: localLikes };
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url; a.download = `fanfig-backup-${new Date().toISOString().slice(0,10)}.json`; a.click();
    URL.revokeObjectURL(url);
  }
  function resetLocal() {
    localStorage.removeItem(LOCAL_STORIES); localStorage.removeItem(LOCAL_BOOKMARKS); localStorage.removeItem(LOCAL_LIKES);
    stories = loadLocalStories(); bookmarks = []; localLikes = []; renderAll(); toast("รีเซ็ตข้อมูล Local แล้ว");
  }
  function confirmBox(title, text, callback) { $("#confirmTitle").textContent = title; $("#confirmText").textContent = text; confirmCallback = callback; $("#confirmModal").classList.add("active"); }

  function bindEvents() {
    ["searchInput","sortSelect","statusSelect","scopeSelect"].forEach(id => $("#"+id).addEventListener(id === "searchInput" ? "input" : "change", renderStories));
    $("#storyForm").addEventListener("submit", createOrUpdateStory);
    $("#commentBtn").addEventListener("click", addComment);
    $("#readerLike").addEventListener("click", () => currentStoryId && toggleLike(currentStoryId));
    $("#readerBookmark").addEventListener("click", () => currentStoryId && toggleBookmark(currentStoryId));
    $("#backToLibrary").addEventListener("click", () => $("#library").scrollIntoView({ behavior:"smooth" }));
    $("#reportBtn").addEventListener("click", () => currentStoryId && $("#reportModal").classList.add("active"));
    $("#sendReportBtn").addEventListener("click", sendReport);
    $("#themeBtn").addEventListener("click", () => applyTheme($("#app").getAttribute("data-theme") === "dark" ? "light" : "dark"));
    $("#randomBtn").addEventListener("click", randomStory);
    $("#exportBtn").addEventListener("click", exportJson);
    $("#refreshBtn").addEventListener("click", () => { if (db) listenPublicStories(); else renderAll(); toast("รีเฟรชแล้ว"); });
    $("#resetBtn").addEventListener("click", () => confirmBox("รีเซ็ตข้อมูล Local", "จะลบข้อมูลที่เก็บในเครื่องนี้เท่านั้น ไม่ลบข้อมูลบน Firebase", resetLocal));
    $("#loginBtn").addEventListener("click", () => $("#authModal").classList.add("active"));
    $("#profileLoginBtn").addEventListener("click", () => $("#authModal").classList.add("active"));
    $("#emailAuthForm").addEventListener("submit", signInEmail);
    $("#signupBtn").addEventListener("click", signupEmail);
    $("#googleBtn").addEventListener("click", () => providerLogin(new firebase.auth.GoogleAuthProvider()));
    $("#facebookBtn").addEventListener("click", () => providerLogin(new firebase.auth.FacebookAuthProvider()));
    $("#logoutBtn").addEventListener("click", logout);
    $("#editStoryBtn").addEventListener("click", startEditStory);
    $("#cancelEditBtn").addEventListener("click", cancelEdit);
    $("#deleteStoryBtn").addEventListener("click", () => confirmBox("ลบเรื่องนี้", "เมื่อลบแล้วจะกู้คืนจากหน้าเว็บไม่ได้ ต้องการลบจริงไหม?", deleteCurrentStory));
    $("#openChapterModalBtn").addEventListener("click", openChapterModal);
    $("#chapterSelect").addEventListener("change", loadChapterIntoForm);
    $("#saveChapterBtn").addEventListener("click", saveChapter);
    $("#deleteChapterBtn").addEventListener("click", () => confirmBox("ลบตอนนี้", "ต้องการลบตอนที่เลือกจริงไหม?", deleteChapter));
    $("#confirmActionBtn").addEventListener("click", async () => { const fn = confirmCallback; confirmCallback = null; $("#confirmModal").classList.remove("active"); if (fn) await fn(); });
    $$('[data-close]').forEach(btn => btn.addEventListener("click", () => $("#"+btn.dataset.close).classList.remove("active")));
    $$('[data-scroll]').forEach(btn => btn.addEventListener("click", () => document.getElementById(btn.dataset.scroll)?.scrollIntoView({ behavior:"smooth" })));
    $$('.nav-btn').forEach(btn => btn.addEventListener("click", () => document.getElementById(btn.dataset.nav)?.scrollIntoView({ behavior:"smooth" })));

    const sections = ["home","library","bookmarks","write","profile"].map(id => document.getElementById(id));
    const observer = new IntersectionObserver(entries => {
      const visible = entries.filter(e => e.isIntersecting).sort((a,b)=>b.intersectionRatio-a.intersectionRatio)[0];
      if (!visible) return;
      $$('.nav-btn').forEach(btn => btn.classList.toggle("active", btn.dataset.nav === visible.target.id));
    }, { threshold:.35 });
    sections.forEach(section => observer.observe(section));
  }

  function boot() {
    applyTheme(localStorage.getItem(LOCAL_THEME) || "dark");
    bindEvents();
    renderAll();
    initializeFirebase();
  }
  boot();
</script>

<!--
FANFIG Firebase Firestore Rules แนะนำสำหรับเริ่มทดสอบจริง
ไปที่ Firebase Console > Firestore Database > Rules แล้วปรับตามนี้

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /stories/{storyId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /reports/{reportId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}

หมายเหตุ:
- ถ้าจะให้ผู้ใช้ทั่วไปคอมเมนต์/ไลก์บน stories โดยไม่ใช่เจ้าของ อาจต้องแยก comments/likes เป็น subcollection หรือปรับ rules เพิ่ม
- เวอร์ชันนี้เหมาะเป็น MVP/ต้นแบบใช้งานจริงระดับเริ่มต้น หากเปิดสาธารณะควรเพิ่มระบบแอดมินและ moderation เพิ่มเติม
-->
